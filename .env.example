# Copy to .env (or paste these into Portainer's stack environment panel).
# Only DASHBOARD_PASSWORD is required.

# Dashboard login
DASHBOARD_PASSWORD=change-me
# RESTRUO_USERNAME=admin

# Branding
# RESTRUO_TITLE=Restruo

# Host port (container always listens on 8080)
# RESTRUO_PORT=8080

# Tags treated as rolling for update checks. Add others if you run projects
# that ship on them, e.g. immich's :release.
# RESTRUO_FLOATING_TAGS=latest,release

# How often an open dashboard re-reads container state, in seconds. 0 disables.
# RESTRUO_REFRESH_SECONDS=180
